% Creative Wheel House Report Template
% For use with: pandoc --template=cwh-report.latex
%
% Usage:
%   pandoc CHANGELOG.md -o report.pdf \
%     --pdf-engine=xelatex \
%     --template=cwh-report.latex \
%     -V title="Progress Report" \
%     -V author="Jeremy Longshore" \
%     -V date="January 9, 2026"

\documentclass[11pt,a4paper]{article}

% Page geometry
\usepackage{geometry}
\geometry{margin=1in}

% Typography
\usepackage{fontspec}
\setmainfont{DejaVu Sans}[Scale=0.95]
\setmonofont{DejaVu Sans Mono}[Scale=0.85]

% Headers and footers
\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\small\textcolor{CWHGray}{Creative Wheel House}}
\fancyhead[R]{\small\textcolor{CWHGray}{Progress Report}}
\fancyfoot[C]{\small\textcolor{CWHGray}{\thepage}}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0pt}

% Colors
\usepackage{xcolor}
\definecolor{CWHBlue}{RGB}{31,78,121}
\definecolor{CWHGray}{RGB}{89,89,89}
\definecolor{CWHLightGray}{RGB}{245,245,245}

% Hyperlinks
\usepackage{hyperref}
\hypersetup{
  colorlinks=true,
  linkcolor=CWHBlue,
  urlcolor=CWHBlue,
  citecolor=CWHBlue
}

% Section styling
\usepackage{titlesec}
\titleformat{\section}
  {\Large\bfseries\color{CWHBlue}}
  {\thesection}{1em}{}
\titleformat{\subsection}
  {\large\bfseries\color{CWHGray}}
  {\thesubsection}{1em}{}
\titleformat{\subsubsection}
  {\normalsize\bfseries\color{CWHGray}}
  {\thesubsubsection}{1em}{}

% Lists
\usepackage{enumitem}
\setlist[itemize]{leftmargin=*,itemsep=0.25em}
\setlist[enumerate]{leftmargin=*,itemsep=0.25em}

% Tables
\usepackage{booktabs}
\usepackage{longtable}
\usepackage{array}

% Code blocks
\usepackage{listings}
\lstset{
  basicstyle=\small\ttfamily,
  backgroundcolor=\color{CWHLightGray},
  frame=single,
  framerule=0pt,
  breaklines=true,
  columns=fullflexible
}

% Graphics
\usepackage{graphicx}

% Better paragraphs
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.5em}

% Title formatting
\usepackage{titling}
\pretitle{\begin{center}\LARGE\bfseries\color{CWHBlue}}
\posttitle{\end{center}\vspace{0.5em}}
\preauthor{\begin{center}\large\color{CWHGray}}
\postauthor{\end{center}}
\predate{\begin{center}\normalsize\color{CWHGray}}
\postdate{\end{center}\vspace{1em}}

% Document metadata
\title{$title$}
\author{$author$}
\date{$date$}

\begin{document}

$if(title)$
\maketitle
$endif$

$if(toc)$
\tableofcontents
\newpage
$endif$

$body$

\end{document}
