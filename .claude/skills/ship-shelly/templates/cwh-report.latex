% Creative Wheel House - Professional Report Template
% Clean, sophisticated, enterprise-grade
%
% Usage:
%   pandoc CHANGELOG.md -o report.pdf \
%     --pdf-engine=xelatex \
%     --template=cwh-report.latex \
%     -V title="Progress Report" \
%     -V author="Jeremy Longshore" \
%     -V date="January 9, 2026"

\documentclass[11pt,letterpaper]{article}

% =============================================================================
% PACKAGES (in dependency order)
% =============================================================================

% Page geometry - professional margins
\usepackage{geometry}
\geometry{
  margin=1in,
  top=1.25in,
  bottom=1in
}

% Colors - defined early for use in other packages
\usepackage{xcolor}
\definecolor{CWHBlue}{RGB}{31,78,121}
\definecolor{CWHDarkBlue}{RGB}{20,50,80}
\definecolor{CWHGray}{RGB}{89,89,89}
\definecolor{CWHLightGray}{RGB}{248,249,250}
\definecolor{CWHAccent}{RGB}{52,152,219}

% Typography - professional fonts
\usepackage{fontspec}
\setmainfont{DejaVu Serif}[Scale=0.95]
\setsansfont{DejaVu Sans}[Scale=0.95]
\setmonofont{DejaVu Sans Mono}[Scale=0.85]

% Required for pandoc table column calculations
\usepackage{calc}

% Headers and footers
\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\small\color{CWHGray}\textsf{Creative Wheel House}}
\fancyhead[R]{\small\color{CWHGray}\textsf{Progress Update}}
\fancyfoot[C]{\small\color{CWHGray}\thepage}
\renewcommand{\headrulewidth}{0.5pt}
\renewcommand{\footrulewidth}{0pt}
\renewcommand{\headrule}{\hbox to\headwidth{\color{CWHLightGray}\leaders\hrule height \headrulewidth\hfill}}

% Hyperlinks
\usepackage{hyperref}
\hypersetup{
  colorlinks=true,
  linkcolor=CWHBlue,
  urlcolor=CWHAccent,
  citecolor=CWHBlue,
  pdfborder={0 0 0}
}

% Section styling - clean and professional
\usepackage{titlesec}
\titleformat{\section}
  {\Large\bfseries\sffamily\color{CWHDarkBlue}}
  {\thesection}{1em}{}
\titleformat{\subsection}
  {\large\bfseries\sffamily\color{CWHBlue}}
  {\thesubsection}{1em}{}
\titleformat{\subsubsection}
  {\normalsize\bfseries\sffamily\color{CWHGray}}
  {\thesubsubsection}{1em}{}
\titlespacing*{\section}{0pt}{2em}{1em}
\titlespacing*{\subsection}{0pt}{1.5em}{0.75em}
\titlespacing*{\subsubsection}{0pt}{1em}{0.5em}

% Lists
\usepackage{enumitem}
\setlist[itemize]{leftmargin=1.5em,itemsep=0.3em,topsep=0.5em}
\setlist[enumerate]{leftmargin=1.5em,itemsep=0.3em,topsep=0.5em}

% Pandoc tight list support
\providecommand{\tightlist}{%
  \setlength{\itemsep}{0pt}\setlength{\parskip}{0pt}}

% Tables - professional styling
\usepackage{booktabs}
\usepackage{longtable}
\usepackage{array}
\renewcommand{\arraystretch}{1.3}

% Code blocks
\usepackage{listings}
\lstset{
  basicstyle=\small\ttfamily,
  backgroundcolor=\color{CWHLightGray},
  frame=none,
  breaklines=true,
  columns=fullflexible,
  xleftmargin=1em,
  xrightmargin=1em,
  aboveskip=1em,
  belowskip=1em
}

% Graphics - for embedded diagrams
\usepackage{graphicx}
\graphicspath{{./}{./graphics/}}

% Landscape pages for wide diagrams
\usepackage{pdflscape}

% Better paragraphs
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.75em}

% Title formatting - professional and clean
\usepackage{titling}
\pretitle{\begin{center}\LARGE\bfseries\sffamily\color{CWHDarkBlue}}
\posttitle{\end{center}\vspace{0.25em}}
\preauthor{\begin{center}\large\color{CWHGray}\sffamily}
\postauthor{\end{center}}
\predate{\begin{center}\normalsize\color{CWHGray}}
\postdate{\end{center}\vspace{1.5em}\hrule\vspace{1em}}

% =============================================================================
% DOCUMENT METADATA
% =============================================================================

\title{$title$}
\author{$author$}
\date{$date$}

% =============================================================================
% DOCUMENT
% =============================================================================

\begin{document}

$if(title)$
\maketitle
$endif$

$if(toc)$
\tableofcontents
\newpage
$endif$

$body$

\end{document}
